# ── LLM Configuration (optional) ─────────────────────────
# The organism runs on rule-based reasoning by default.
# Set these to enable LLM-powered brain analysis.

# Provider: "auto" | "ollama" | "nvidia" | "openai"
LLM_PROVIDER=auto

# Ollama (local — zero cost)
OLLAMA_URL=http://localhost:11434

# NVIDIA NIM (free tier)
# NVIDIA_API_KEY=nvapi-xxxxx

# OpenAI (paid — last resort)
# OPENAI_API_KEY=sk-xxxxx

# ── Tuning ───────────────────────────────────────────────
# LLM_MODEL=          # Override auto-detected model
# LLM_TIMEOUT_S=30    # LLM request timeout
# LLM_MAX_TOKENS=1024 # Max tokens per LLM response
